# Copy to .dev.vars for local OpenNext/Wrangler preview (do not commit .dev.vars)
NEXTJS_ENV=development

# --- Cloudflare dashboard setup (REQUIRED before deploy succeeds) ---
# 1. Workers & Pages → digitaltest → Settings → Variables and Secrets
# 2. Add encrypted Secret: AUTH_SECRET = output of `openssl rand -base64 32`
# 3. (Optional) Add encrypted Secret: AUTH_URL = https://your-worker.workers.dev
#
# Build/deploy commands (Workers Builds):
#   Build:  npm run build:cloudflare
#   Deploy: npx wrangler deploy
# Or single step: npm run deploy
#
# Do NOT use the manual node_modules stubbing bash command.

# AUTH_SECRET=
# AUTH_URL=https://your-worker.workers.dev

# Optional
# OPENAI_API_KEY=
# TRANSCRIPTION_PROVIDER=openai
