# Copy to .dev.vars for local OpenNext/Wrangler preview (do not commit .dev.vars)
NEXTJS_ENV=development

# Cloudflare Workers Builds — use these commands (do NOT manually stub node_modules):
#   Build:  npm run build:cloudflare
#   Deploy: npx opennextjs-cloudflare deploy
# Or as a single step: npm run deploy

# REQUIRED — set as encrypted Secrets in Cloudflare dashboard (Settings → Variables and Secrets)
# Also add to Workers Builds → Build variables and secrets (same names)
# Generate: openssl rand -base64 32
# AUTH_SECRET=
# AUTH_URL=https://your-worker.workers.dev

# Optional
# OPENAI_API_KEY=
# TRANSCRIPTION_PROVIDER=openai
