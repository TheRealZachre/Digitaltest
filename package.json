{
  "name": "social-insights-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "node scripts/postinstall.mjs",
    "dev:analytics": "npm run dev --prefix apps/analytics",
    "dev:all": "concurrently -n main,analytics -c blue,green \"npm run dev\" \"npm run dev:analytics\"",
    "build": "next build",
    "build:cloudflare": "OPENNEXT_CLOUDFLARE=1 opennextjs-cloudflare build",
    "build:cloudflare:ci": "bash scripts/cloudflare-build.sh",
    "ci:cloudflare": "bash scripts/cloudflare-ci.sh",
    "deploy:cloudflare": "bash scripts/cloudflare-deploy.sh",
    "setup:cloudflare": "bash scripts/setup-cloudflare-auth.sh",
    "preview": "OPENNEXT_CLOUDFLARE=1 opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run build:cloudflare && npm run deploy:cloudflare",
    "build:analytics": "npm run build --prefix apps/analytics",
    "start": "next start",
    "lint": "eslint",
    "sync:linkedin": "tsx scripts/sync-linkedin.ts",
    "sync:linkedin:seed": "tsx scripts/sync-linkedin.ts seed",
    "sync:social": "tsx scripts/sync-social.ts",
    "import:channels": "tsx scripts/import-channels.ts",
    "refresh:facebook-images": "tsx scripts/refresh-facebook-images.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.42.0",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "wavefile": "^11.0.0",
    "xlsx": "^0.18.5",
    "@opennextjs/cloudflare": "^1.19.11",
    "wrangler": "^4.100.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
